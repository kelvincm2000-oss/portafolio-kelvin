---
// src/components/ContactSection.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contacto" class="relative min-h-[80vh] bg-forest-dark py-32 px-6 md:px-12 flex flex-col justify-center overflow-hidden uppercase font-black text-white">
  <!-- Dynamic Background: Moving Mesh or Grid -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div class="h-full w-full" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 60px 60px;"></div>
  </div>

  <div class="container mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      
      <!-- Left: Massive Text & Socials -->
      <div class="flex flex-col space-y-12">
        <div class="space-y-4">
          <span class="text-forest-green text-xs tracking-[0.4em] block animate-pulse">{t('contact.status')}</span>
      <h2 class="text-[clamp(3.5rem,10vw,8rem)] leading-[0.85] tracking-tighter text-white drop-shadow-sm">
            {lang === 'es' ? '¿TIENES UNA ' : 'HAVE AN '}
            <span class="text-forest-green">IDEA</span>?
            <br/>
            {t('contact.subtitle')}
          </h2>
        </div>

        <div class="flex flex-col space-y-6 pt-10 border-t border-white/10">
          <p class="text-xs font-bold text-white/70 tracking-widest">{t('contact.find_me')}</p>
          <div class="flex flex-wrap gap-x-12 gap-y-6">
            <a href="https://www.instagram.com/kelvincm2000/" target="_blank" class="text-sm tracking-widest text-white/90 hover:text-forest-green transition-all duration-300 relative group">
              Instagram
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-forest-green transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="https://www.behance.net/kelvincadrazco" target="_blank" class="text-sm tracking-widest text-white/90 hover:text-forest-green transition-all duration-300 relative group">
              Behance
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-forest-green transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="mailto:kelvincm2000@gmail.com" class="text-sm tracking-widest text-white/90 hover:text-forest-green transition-all duration-300 relative group">
              Email
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-forest-green transition-all duration-300 group-hover:w-full"></span>
            </a>
          </div>
        </div>
      </div>

      <!-- Right: Action Card / Contact Info -->
      <div class="relative group">
        <!-- Floating Sticker/Badge -->
        <div class="absolute -top-10 -right-4 md:-right-10 bg-forest-green text-white px-6 py-6 rounded-full rotate-12 shadow-2xl z-20 flex flex-col items-center justify-center animate-bounce duration-[3s]">
          <span class="text-[9px] tracking-[0.2em]">LET'S</span>
          <span class="text-lg font-black italic">TALK</span>
        </div>

        <div class="bg-white text-forest-dark p-12 rounded-4xl shadow-2xl transition-all duration-700 group-hover:-rotate-1 group-hover:scale-[1.02]">
          <div class="flex flex-col space-y-8 text-center sm:text-left">
            <h3 class="text-2xl tracking-tighter uppercase">{t('contact.ready')}</h3>
            <p class="text-sm font-bold text-forest-dark/80 leading-relaxed uppercase">
              {t('contact.desc')}
            </p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-4">
              <a href="mailto:kelvincm2000@gmail.com" class="flex flex-col items-center justify-center py-6 bg-forest-dark text-white rounded-2xl text-[10px] tracking-[0.2em] font-black hover:bg-forest-green transition-colors duration-500 shadow-xl shadow-forest-dark/20 uppercase whitespace-nowrap px-4 leading-none">
                <span class="opacity-70 mb-2">Email</span>
                kelvincm2000@gmail.com
              </a>
              <a href={`https://wa.me/584125349040?text=${encodeURIComponent(t('whatsapp.message'))}`} target="_blank" class="flex flex-col items-center justify-center py-6 bg-white border-2 border-forest-dark text-forest-dark rounded-2xl text-[10px] tracking-[0.2em] font-black hover:bg-forest-dark hover:text-white transition-all duration-500 uppercase leading-none">
                <span class="opacity-70 mb-2">{t('contact.chat')}</span>
                WhatsApp
              </a>
            </div>
          </div>
        </div>
        
        <!-- Decorative elements around the card -->
        <div class="absolute -bottom-6 -left-6 w-24 h-24 bg-forest-green/20 rounded-full blur-2xl group-hover:bg-forest-green/40 transition-colors"></div>
      </div>
    </div>
  </div>

  <!-- Footer Info inside Section -->
  <div class="container mx-auto mt-32 pt-12 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-8 opacity-80">
    <span class="text-[10px] tracking-widest text-white/90">© 2026 KELVIN DESIGN</span>
    <div class="flex gap-8">
      <span class="text-[10px] tracking-widest text-white/90 uppercase">{t('contact.rights')}</span>
    </div>
  </div>
</section>

<style>
  #contacto {
    background-color: #132a13;
    position: relative;
    overflow: hidden;
  }

  /* Textura de grano estática y orgánica */
  #contacto::before {
    content: "";
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.12; /* Balance perfecto para que se note sin molestar */
    pointer-events: none;
    z-index: 1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 250 250' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    mix-blend-mode: overlay;
  }
</style>
