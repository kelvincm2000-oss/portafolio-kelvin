---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const whatsappMessage = encodeURIComponent(t('whatsapp.message'));
---

<a 
  href={`https://wa.me/584125349040?text=${whatsappMessage}`} 
  target="_blank" 
  rel="noopener noreferrer"
  id="floating-whatsapp"
  class="fixed bottom-8 right-8 z-90 p-4 bg-[#25D366]/10 backdrop-blur-xl border border-[#25D366]/20 rounded-2xl flex items-center gap-3 group translate-y-20 opacity-0 transition-all duration-700 ease-premium shadow-2xl hover:scale-105 hover:bg-[#25D366]/20 active:scale-95"
  aria-label="Contact via WhatsApp"
>
  <!-- WhatsApp Icon with premium look -->
  <div class="relative w-8 h-8 flex items-center justify-center">
    <svg 
      class="w-full h-full fill-[#25D366] drop-shadow-[0_0_8px_rgba(37,211,102,0.6)]" 
      role="img" 
      viewBox="0 0 24 24" 
      xmlns="http://www.w3.org/2000/svg"
    >
      <title>WhatsApp</title>
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
    </svg>
    <!-- Animation Ring -->
    <span class="absolute inset-0 rounded-full border-2 border-[#25D366] animate-ping opacity-20 scale-150"></span>
  </div>

  <div class="flex flex-col pr-2 overflow-hidden w-0 group-hover:w-32 transition-all duration-500 ease-out">
    <span class="text-[10px] font-black tracking-widest text-[#25D366] uppercase leading-none opacity-0 group-hover:opacity-100 transition-opacity duration-300">WhatsApp</span>
    <span class="text-[9px] font-bold text-forest-green tracking-tighter leading-none mt-1 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-500">{t('whatsapp.label')}</span>
  </div>
</a>

<script>
  import { gsap } from "../lib/gsap";

  const btn = document.getElementById('floating-whatsapp');

  if (btn) {
    // Reveal after 2 seconds
    gsap.to(btn, {
      y: 0,
      opacity: 1,
      duration: 1.5,
      delay: 2,
      ease: "expo.out"
    });

    // Suble interaction logic
    btn.addEventListener('mouseenter', () => {
      gsap.to(btn, {
        backgroundColor: "rgba(37, 211, 102, 0.15)",
        borderColor: "rgba(37, 211, 102, 0.4)",
        duration: 0.3
      });
    });

    btn.addEventListener('mouseleave', () => {
      gsap.to(btn, {
        backgroundColor: "rgba(37, 211, 102, 0.1)",
        borderColor: "rgba(37, 211, 102, 0.2)",
        duration: 0.3
      });
    });
  }
</script>

<style>
  #floating-whatsapp {
    box-shadow: 0 25px 50px -12px rgba(37, 211, 102, 0.25);
  }
  .ease-premium {
    transition-timing-function: cubic-bezier(0.23, 1, 0.32, 1);
  }
</style>
